# Django Settings
DJANGO_SECRET_KEY=django-insecure-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database
# Local development uses SQLite by default.
# For production on Render, set DATABASE_URL from the dashboard.
DATABASE_URL=

# Media storage
# Local development defaults to filesystem MEDIA_ROOT.
# Production can use any S3-compatible object storage (AWS S3, Cloudflare R2, Supabase S3, etc.).
USE_S3_MEDIA_STORAGE=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=False
AWS_S3_FILE_OVERWRITE=False
AWS_LOCATION=

# Celery & Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
DEV_SYNC_MODE=False
DEV_SYNC_MAX_VIDEO_SECONDS=300
RENDER_LIGHT_MODE=False
RENDER_TRANSCRIPT_ONLY_MODE=False
RENDER_DEMO_SAFE_ASR_MODE=False
RENDER_DEMO_SAFE_ASR_MAX_RETRIES=1
RENDER_DEMO_SAFE_MAX_VIDEO_SECONDS=300

# AI Models Configuration
WHISPER_MODEL_SIZE=small
ASR_MALAYALAM_PRIMARY_MODEL=
ASR_MALAYALAM_MODEL_FAMILY=auto
ASR_MALAYALAM_COMPUTE_TYPE=int8
WHISPER_MODEL_MALAYALAM_PRIMARY=
WHISPER_MODEL_MALAYALAM_SECONDARY=
WHISPER_MODEL_MALAYALAM_FALLBACK=large-v3
SUMMARIZATION_MODEL=facebook/bart-large-cnn
SUMMARIZATION_PROVIDER=hf
HF_SHORT_MAX_INPUT_WORDS=900
HF_BULLET_MAX_INPUT_WORDS=1200
EMBEDDING_MODEL=BAAI/bge-m3
RAG_PREWARM_EMBEDDING_MODEL=False
RAG_CHUNK_SIZE_WORDS=140
RAG_CHUNK_OVERLAP_WORDS=35
RAG_CHUNK_TARGET_SECONDS=75
RAG_SEMANTIC_CHUNKING=True
RAG_SIMILARITY_THRESHOLD=0.30
RAG_ENABLE_RERANKER=True
RAG_SEARCH_POOL_MULTIPLIER=4
RAG_TOP_K=8
RAG_TOP_K_SUMMARY=8
RAG_TOP_K_FACTUAL=6
RAG_TOP_K_TIMELINE=6
RAG_TOP_K_QUOTE=5
RAG_FINAL_CONTEXT_K=3
RAG_MAX_CONTEXT_WORDS=1500
RAG_MIN_SOURCE_PREVIEW_CHARS=18
USE_GROQ_WHISPER=True
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_WHISPER_ENGLISH_ONLY=False
ASR_LONGFORM_LOCAL_THRESHOLD_SECONDS=900
ASR_USE_DEEPGRAM_FOR_NON_ENGLISH=True
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_BASE_URL=https://api.deepgram.com/v1/listen
DEEPGRAM_TIMEOUT_SEC=180
DEEPGRAM_SUPPORTED_LANGUAGES=en,hi,ta,te,kn,es,fr,de,pt,it,nl,ru,ja,ko,zh,ar,tr,id,sv,no,pl,uk
ASR_LOCAL_MODEL_REUSE=True
ASR_USE_GROQ_FALLBACK=True
ASR_GROQ_COOLDOWN_SEC=900
ASR_LOW_CONTENT_WPM_MIN=20
ASR_LOW_CONTENT_MIN_WORDS_LONG=80
ASR_MAX_RETRIES=3
ASR_REJECT_ON_GARBLE=True
TRANSCRIPT_LLM_CORRECTION_ENABLED=False
TRANSCRIPT_LLM_PROPER_NOUN_ENABLED=False
TRANSCRIPT_LLM_QUALITY_THRESHOLD=0.70
TRANSCRIPT_LLM_MIN_WORDS=80
TRANSCRIPT_LLM_MAX_WORDS=1800
CHATBOT_USE_GROQ_LLM=False
CHAT_ANSWER_QA_ENABLED=True
CHAT_ANSWER_MIN_INFO_TOKENS=6
CHAT_KEY_POINTS_MAX=3
CHAT_MOMENT_CONTEXT_BEFORE_SECONDS=20
CHAT_MOMENT_CONTEXT_AFTER_SECONDS=40
CHAT_MOMENT_MAX_CHUNKS=4
CHAT_MOMENT_MAX_WORDS=90
CHAT_MOMENT_ALLOW_BROADENING=True
ASR_LANGUAGE_DETECT_ENABLED=True
ASR_LANGUAGE_DETECT_MODEL=small
ASR_ENABLE_QUALITY_AWARE_ROUTER=True
ASR_LATENCY_BUDGET_SECONDS=480
ASR_PROVIDER_PRIOR_DEFAULT_QUALITY=0.72
ASR_AUTO_FALLBACK_LANGUAGES=ml,hi,ta,te,kn,en
ASR_MALAYALAM_WARMUP=False
ASR_MALAYALAM_ENABLE_FULL_RETRY=False
ASR_MALAYALAM_RETRY_MIN_QUALITY=0.42
ASR_MALAYALAM_MAX_RETRY_COUNT=1
ASR_MALAYALAM_MAX_TOTAL_SECONDS=420
ASR_MALAYALAM_SKIP_RETRY_ABOVE_DURATION_SECONDS=360
ASR_MALAYALAM_FAST_MODE=True
ASR_MALAYALAM_ENABLE_LARGE_FALLBACK=False
ASR_MALAYALAM_LARGE_FALLBACK_MIN_QUALITY=0.34
ASR_MALAYALAM_ACCEPT_FIRST_PASS_MIN_QUALITY=0.5
ASR_MALAYALAM_ALLOW_USABLE_FIRST_PASS=True
ASR_MALAYALAM_GARBLED_MAX_RATIO=0.34
EMBED_CANONICAL_LANGUAGE=en
CANONICAL_TRANSLATE_SEGMENTS=False
TRANSLATION_PROVIDER=none
GROQ_RATE_LIMIT_COOLDOWN_SEC=180
CANONICAL_TRANSLATION_MODEL=llama-3.3-70b-versatile
TRANSLATION_MAX_WORDS_PER_CALL=1200
TRANSLATION_RETRY_ATTEMPTS=2
TRANSLATION_RETRY_BASE_DELAY_SEC=1.5
TRANSCRIPT_PHRASE_BLACKLIST=Ask AI about this moment|screen recording|click the bell icon|subscribe to the channel
TRANSCRIPT_REGEX_CLEANUP_PATTERNS=(?i)\bask ai about this moment\b||(?i)\bclick the bell icon\b||(?i)\bsubscribe(?: now| to the channel)?\b
SUMMARY_QUALITY_MIN_SCORE=0.62

# OpenAI (optional, for enhanced chatbot)
OPENAI_API_KEY=

# Groq (free LLM API - https://console.groq.com/)
GROQ_API_KEY=

# FFmpeg Path (if not in PATH)
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
